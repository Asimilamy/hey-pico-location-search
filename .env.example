# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWebUI Configuration
OPENWEB_UI_URL=http://localhost:8000
OPENWEB_UI_API_KEY=your_openwebui_api_key_here
OPENWEB_UI_MODEL=mistral  # or any model you choose (llama2, neural-chat, etc)

# FastAPI Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30

# Environment
DEBUG=False
